# Public site origin used by forms, metadata, and API origin checks.
NEXT_PUBLIC_APP_URL=https://aurillia.de
NEXT_PUBLIC_CONTACT_EMAIL=info@aurillia.de

# OpenAI key used only on the server. Never expose this to the browser.
OPENAI_API_KEY=sk-...

# Optional chatbot controls. This example file is not loaded by Vercel.
# Set these in Vercel project environment variables for production.
# In production the bot is disabled unless this is explicitly true.
AURILLIA_CHAT_ENABLED=false
AURILLIA_CHAT_MODEL=gpt-4o-mini
AURILLIA_ALLOWED_ORIGINS=https://aurillia.de,https://www.aurillia.de
AURILLIA_RATE_LIMIT_SALT=replace-with-random-long-string
AURILLIA_CHAT_RATE_LIMIT_MINUTE=6
AURILLIA_CHAT_RATE_LIMIT_HOUR=40
AURILLIA_CHAT_HOURLY_CHAR_BUDGET=18000
AURILLIA_CHAT_MAX_MESSAGE_LENGTH=700
AURILLIA_CHAT_MAX_USER_MESSAGES=5
AURILLIA_CHAT_MAX_TOTAL_INPUT_CHARS=2400
AURILLIA_CHAT_MAX_COMPLETION_TOKENS=320

# Supabase server-side lead/usage logging. Leave unset to disable logging.
# Use a server-only service_role JWT or a newer sb_secret_... key, never a publishable key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-real-supabase-service-role-key

# Contact form routing.
CONTACT_TO=devadacc@gmail.com
CONTACT_FROM=Aurillia <onboarding@resend.dev>
RESEND_API_KEY=re_...
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_MIN_FORM_AGE_MS=2500
CONTACT_MAX_FORM_AGE_MS=86400000
